PRIVATE_KEY=
REDBELLY_MAINNET_RPC_URL=https://governors.mainnet.redbelly.network
REDBELLY_TESTNET_RPC_URL=https://governors.testnet.redbelly.network

# KYC registries (see client.config.ts)
KYC_REGISTRY_ADDRESS=0xcb385cD90ca6b219798F57B4a7958897e91A9163
KYC_REGISTRY_ADDRESS_TESTNET=0x519ba1b48D571FD92FAF6FE4D20fe74Ca435B690

# Production dividend token (required on mainnet; optional on testnet)
